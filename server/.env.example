# Environment configuration for deploying the FastAPI backend

# Secret used for signing tokens or session data.
SECRET_KEY=change-me

# Database connection string. Replace with your managed database URL.
DATABASE_URL=postgresql://username:password@db-host:5432/barbershop

# Optional overrides
APP_NAME=Barbershop Booking API
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# Render automatically provides the PORT variable. Use this when running locally.
# PORT=8000
